# Copy this file to .env and adjust before running `docker-compose up --build`.
# Never commit a real .env with production secrets.

# --- Django -----------------------------------------------------------------
DJANGO_SECRET_KEY=change-this-to-a-long-random-string-in-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Postgres ----------------------------------------------------------------
POSTGRES_DB=voidlab
POSTGRES_USER=voidlab
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --- CORS (frontend origins allowed to call the API) ------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Seed data / bootstrap admin --------------------------------------------
DJANGO_SEED_DATA=true
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@voidlab.local
DJANGO_SUPERUSER_PASSWORD=change-this-password-too

# --- Vulnerable app targets (must match docker-compose port mappings) ------
SQLI_LAB_URL=http://localhost:8081
XSS_LAB_URL=http://localhost:8082
CMDI_LAB_URL=http://localhost:8083
IDOR_LAB_URL=http://localhost:8084
SSRF_LAB_URL=http://localhost:8085

# --- Frontend build-time API targets ----------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
